.rev-photo img{width:100%;height:auto;object-fit:cover}
@media(max-width:700px){.review-grid{grid-template-columns:repeat(3,1fr)}}
.testimonials{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.25rem;margin-bottom:2.5rem}
.t-card{background:var(--d3);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:1.5rem}
.t-stars{color:var(--pk);font-size:.9rem;letter-spacing:.05em;margin-bottom:.75rem}
.t-card p{font-size:.9rem;font-style:italic;color:var(--tx);margin-bottom:.75rem;line-height:1.75}
.t-card cite{font-size:.8rem;color:var(--cy);font-weight:700;font-style:normal}
.press-row{text-align:center;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,.06);display:flex;gap:2rem;justify-content:center;align-items:center;flex-wrap:wrap}
.press-l{font-size:.68rem;text-transform:uppercase;letter-spacing:.12em;color:var(--mt)}
.press-row span{font-weight:700;color:rgba(237,232,248,.5);font-size:.875rem}

/* INCLUSIONS */
.inc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem}
.inc{background:var(--d2);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:1.75rem;transition:border-color .25s,box-shadow .25s}
.inc:hover{border-color:rgba(233,30,204,.25);box-shadow:0 0 28px rgba(233,30,204,.08)}
.ii{font-size:2rem;margin-bottom:.875rem}
.inc h4{font-size:.95rem;font-weight:700;color:var(--wh);margin-bottom:.4rem}
.inc p{font-size:.85rem;color:var(--mt)}

/* FAQ */
.faq{max-width:720px;display:flex;flex-direction:column;gap:.4rem}
.faq details{background:var(--d3);border:1px solid rgba(255,255,255,.06);border-radius:8px;overflow:hidden}
.faq summary{padding:1.1rem 1.25rem;font-weight:600;font-size:.95rem;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;color:var(--wh)}
.faq summary::after{content:'+';color:var(--pk);font-size:1.25rem;font-weight:300;flex-shrink:0}
.faq details[open] summary::after{content:'−'}
.faq details[open] summary{color:var(--pk)}
.faq div{padding:0 1.25rem 1.1rem;font-size:.9rem;color:var(--mt);line-height:1.75}

/* FINAL CTA */
.fcta{position:relative;padding:8rem 1.5rem;text-align:center;overflow:hidden}
.fcta-bg{position:absolute;inset:0}
.fcta-bg img{width:100%;height:100%;object-fit:cover}
.fcta-shade{position:absolute;inset:0;background:rgba(6,6,8,.87)}
.fcta-body{position:relative;z-index:2}
.fcta-logo{height:72px;width:auto;margin:0 auto 2rem;filter:drop-shadow(0 0 20px rgba(233,30,204,.55))}
.fcta h2{font-size:clamp(2rem,5vw,3.25rem);color:var(--wh);margin-bottom:.75rem}
.fcta>div>p{color:var(--mt);font-size:1.05rem;margin-bottom:2rem}
.fcta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:1.25rem}
.fcta-note{font-size:.78rem;color:var(--mt)}

/* FOOTER */
footer{background:#040406;border-top:1px solid rgba(255,255,255,.05);padding:3.5rem 1.5rem 0}
.foot-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:3rem;margin-bottom:3rem}
@media(max-width:640px){.foot-grid{grid-template-columns:1fr;gap:2rem}}
.foot-grid>div{display:flex;flex-direction:column;gap:.65rem}
.foot-grid img{filter:drop-shadow(0 0 8px rgba(233,30,204,.3))}
.foot-grid p{font-size:.8rem;color:var(--mt);line-height:1.8}
.foot-grid p a{color:var(--mt);transition:color .2s}
.foot-grid p a:hover{color:var(--cy)}
.foot-grid h5{font-size:.72rem;text-transform:uppercase;letter-spacing:.12em;color:var(--mt);font-weight:700}
.foot-grid a{font-size:.85rem;color:rgba(237,232,248,.4);transition:color .2s}
.foot-grid a:hover{color:var(--pk)}
.foot-bottom{border-top:1px solid rgba(255,255,255,.05);padding:1.25rem 0;font-size:.75rem;color:var(--mt);text-align:center}
</style>

<script>
// Mobile nav
const burger = document.getElementById('burger');
const mobNav = document.getElementById('mob-nav');
burger?.addEventListener('click', () => mobNav?.classList.toggle('open'));
mobNav?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mobNav?.classList.remove('open')));

// Club finder
const schedule: Record<number,{clubs:string[];blackout:boolean}> = {
  0:{clubs:['XS at Encore','Hakkasan at MGM Grand','Marquee at Cosmopolitan','Zouk at Resorts World','Foundation Room at Mandalay Bay'],blackout:false},
  1:{clubs:['On The Record at Park MGM','Foundation Room at Mandalay Bay','Ghostbar at Palms'],blackout:false},
  2:{clubs:['On The Record at Park MGM','Foundation Room at Mandalay Bay','Ghostbar at Palms'],blackout:false},
  3:{clubs:['Marquee at Cosmopolitan','Omnia at Caesars Palace','Tao at Venetian','On The Record at Park MGM','Zouk at Resorts World'],blackout:false},
  4:{clubs:['Marquee at Cosmopolitan','Hakkasan at MGM Grand','Omnia at Caesars Palace','Tao at Venetian','Foundation Room at Mandalay Bay','LIV at Fontainebleau'],blackout:false},
  5:{clubs:['Jewel at Aria','Marquee at Cosmopolitan','Hakkasan at MGM Grand','Omnia at Caesars Palace','XS at Encore','Zouk at Resorts World','LIV at Fontainebleau','Tao at Venetian','EBC @ Night at Encore','Foundation Room at Mandalay Bay'],blackout:true},
  6:{clubs:['Jewel at Aria','Marquee at Cosmopolitan','Hakkasan at MGM Grand','Omnia at Caesars Palace','XS at Encore','Zouk at Resorts World','LIV at Fontainebleau','Tao at Venetian','EBC @ Night at Encore','Foundation Room at Mandalay Bay','On The Record at Park MGM'],blackout:true},
};
const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const input=document.getElementById('eDate') as HTMLInputElement;
const results=document.getElementById('fResults');
const fDay=document.getElementById('fDay');
const fCount=document.getElementById('fCount');
const fGrid=document.getElementById('fGrid');
const fBlackout=document.getElementById('fBlackout');
const now=new Date();
input.min=`${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
input.addEventListener('change',()=>{
  const [y,m,d]=input.value.split('-').map(Number);
  if(!y)return;
  const date=new Date(y,m-1,d);
  const day=date.getDay();
  const data=schedule[day];
  if(fDay)fDay.textContent=`${days[day]}, ${date.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}`;
  if(fCount)fCount.textContent=`${data.clubs.length} clubs typically available this night`;
  if(fGrid)fGrid.innerHTML=data.clubs.map(c=>`<div class="f-chip">${c}</div>`).join('');
  fBlackout?.classList.toggle('hidden',!data.blackout);
  results?.classList.remove('hidden');
});
</script>
