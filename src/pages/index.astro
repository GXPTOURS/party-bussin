<script>
// Mobile menu
const hamburger = document.getElementById('hamburger');
const mobileMenu = document.getElementById('mobileMenu');
hamburger?.addEventListener('click', () => mobileMenu?.classList.toggle('open'));
mobileMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mobileMenu?.classList.remove('open')));

// Club finder
const clubSchedule: Record<number, { clubs: string[]; blackout: boolean }> = {
  0: { clubs: ['XS at Encore','Hakkasan at MGM Grand','Marquee at Cosmopolitan','Zouk at Resorts World','Foundation Room at Mandalay Bay'], blackout: false },
  1: { clubs: ['On The Record at Park MGM','Foundation Room at Mandalay Bay','Ghostbar at Palms'], blackout: false },
  2: { clubs: ['On The Record at Park MGM','Foundation Room at Mandalay Bay','Ghostbar at Palms'], blackout: false },
  3: { clubs: ['Marquee at Cosmopolitan','Omnia at Caesars Palace','Tao at Venetian','On The Record at Park MGM','Zouk at Resorts World'], blackout: false },
  4: { clubs: ['Marquee at Cosmopolitan','Hakkasan at MGM Grand','Omnia at Caesars Palace','Tao at Venetian','Foundation Room at Mandalay Bay','LIV at Fontainebleau'], blackout: false },
  5: { clubs: ['Jewel at Aria','Marquee at Cosmopolitan','Hakkasan at MGM Grand','Omnia at Caesars Palace','XS at Encore','Zouk at Resorts World','LIV at Fontainebleau','Tao at Venetian','EBC @ Night at Encore','Foundation Room at Mandalay Bay'], blackout: true },
  6: { clubs: ['Jewel at Aria','Marquee at Cosmopolitan','Hakkasan at MGM Grand','Omnia at Caesars Palace','XS at Encore','Zouk at Resorts World','LIV at Fontainebleau','Tao at Venetian','EBC @ Night at Encore','Foundation Room at Mandalay Bay','On The Record at Park MGM'], blackout: true },
};

const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

const input = document.getElementById('eventDate') as HTMLInputElement;
const results = document.getElementById('clubResults');
const resDay = document.getElementById('resultsDay');
const resCnt = document.getElementById('resultsCount');
const grid = document.getElementById('clubGrid');
const blackout = document.getElementById('blackoutNote');

// Set min date to today
const now = new Date();
input.min = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;

input.addEventListener('change', () => {
  const [y,m,d] = input.value.split('-').map(Number);
  if (!y) return;
  const date = new Date(y, m-1, d);
  const day = date.getDay();
  const data = clubSchedule[day];
  if (resDay) resDay.textContent = `${dayNames[day]}, ${date.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}`;
  if (resCnt) resCnt.textContent = `${data.clubs.length} clubs typically available this night`;
  if (grid) grid.innerHTML = data.clubs.map(c => `<div class="club-chip">${c}</div>`).join('');
  blackout?.classList.toggle('hidden', !data.blackout);
  results?.classList.remove('hidden');
});
</script>
