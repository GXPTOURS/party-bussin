<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --pk:#E91ECC;--pk2:#FF3DE8;--pu:#7B2FBE;--pu2:#9B4FDE;
  --cy:#00E5FF;--bk:#060608;--d1:#0D0D14;--d2:#13131C;--d3:#1C1C28;
  --tx:#EDE8F8;--mt:#7870A0;--wh:#fff;
  --grad:linear-gradient(135deg,var(--pk),var(--pu));
}
html{scroll-behavior:smooth}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bk);color:var(--tx);line-height:1.65;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}
h1,h2,h3,h4{line-height:1.15;font-weight:800}
.grad{background:linear-gradient(90deg,var(--pk2),var(--pu2),var(--cy));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

/* BUTTONS */
.btn-p{display:inline-flex;align-items:center;gap:.4rem;background:var(--grad);color:#fff;font-weight:700;font-size:.95rem;padding:.9rem 2rem;border-radius:8px;box-shadow:0 0 28px rgba(233,30,204,.4);transition:opacity .2s,transform .15s,box-shadow .2s;white-space:nowrap}
.btn-p:hover{opacity:.88;transform:translateY(-2px);box-shadow:0 0 44px rgba(233,30,204,.65)}
.btn-g{display:inline-flex;align-items:center;gap:.4rem;background:transparent;color:var(--wh);font-weight:600;font-size:.95rem;padding:.9rem 2rem;border-radius:8px;border:2px solid rgba(255,255,255,.2);transition:border-color .2s,color .2s;white-space:nowrap}
.btn-g:hover{border-color:var(--cy);color:var(--cy)}
.btn-xl{padding:1.15rem 2.75rem;font-size:1.08rem}

/* NAV */
#nav{position:sticky;top:0;z-index:300;background:rgba(6,6,8,.95);backdrop-filter:blur(18px);border-bottom:1px solid rgba(233,30,204,.15)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 1.5rem;height:70px;display:flex;align-items:center;gap:2rem}
.logo img{height:46px;width:auto;filter:drop-shadow(0 0 10px rgba(233,30,204,.4))}
nav{display:flex;gap:1.5rem;flex:1}
nav a{font-size:.875rem;color:var(--mt);font-weight:500;transition:color .2s}
nav a:hover{color:var(--wh)}
.nav-right{display:flex;align-items:center;gap:1rem;margin-left:auto}
.nav-tel{font-size:.875rem;color:var(--cy);font-weight:700;white-space:nowrap}
.nav-book{background:var(--grad);color:#fff;font-weight:700;padding:.55rem 1.35rem;border-radius:7px;font-size:.875rem;box-shadow:0 0 16px rgba(233,30,204,.3);transition:opacity .2s;white-space:nowrap}
.nav-book:hover{opacity:.85}
#burger{display:none;background:none;border:none;color:var(--wh);font-size:1.5rem;cursor:pointer;margin-left:auto;padding:.25rem}
#mob-nav{display:none;flex-direction:column;gap:.5rem;padding:1rem 1.5rem 1.5rem;border-top:1px solid rgba(255,255,255,.06)}
#mob-nav a{padding:.55rem 0;color:var(--mt);border-bottom:1px solid rgba(255,255,255,.05)}
.mob-book{background:var(--grad)!important;color:#fff!important;font-weight:700;padding:.75rem!important;border-radius:8px;text-align:center;margin-top:.5rem;border:none!important;box-shadow:0 0 16px rgba(233,30,204,.3)}
#mob-nav.open{display:flex}
@media(max-width:900px){nav,.nav-tel{display:none}#burger{display:block}.nav-book{display:none}}

/* HERO */
.hero{position:relative;min-height:100svh;display:flex;align-items:center;justify-content:center;overflow:hidden}
.hero-bg{position:absolute;inset:0}
.hero-vid{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0}
.hero-fallback{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:-1}
.hero-shade{position:absolute;inset:0;background:linear-gradient(180deg,rgba(6,6,8,.25) 0%,rgba(6,6,8,.6) 50%,rgba(6,6,8,.97) 100%);z-index:1}
.blob{position:absolute;border-radius:50%;pointer-events:none;filter:blur(80px);z-index:1}
.blob-l{width:600px;height:600px;top:5%;left:-15%;background:radial-gradient(circle,rgba(233,30,204,.22),transparent 70%);opacity:.7}
.blob-r{width:500px;height:500px;bottom:5%;right:-12%;background:radial-gradient(circle,rgba(0,229,255,.16),transparent 70%);opacity:.7}
.hero-body{position:relative;z-index:2;text-align:center;padding:5rem 1.5rem 3rem;max-width:900px;width:100%}
.badge{display:inline-flex;align-items:center;gap:.5rem;background:rgba(233,30,204,.12);border:1px solid rgba(233,30,204,.35);color:var(--pk2);padding:.4rem 1.1rem;border-radius:999px;font-size:.78rem;font-weight:600;letter-spacing:.04em;margin-bottom:1.75rem}
.stars{letter-spacing:.05em}
h1{font-size:clamp(2.6rem,7.5vw,5.5rem);font-weight:900;color:var(--wh);margin-bottom:1.25rem}
.sub{font-size:clamp(1rem,2.5vw,1.2rem);color:rgba(237,232,248,.78);max-width:640px;margin:0 auto 1rem}
.sub strong{color:var(--wh)}
.press-strip{font-size:.78rem;color:var(--mt);margin-bottom:2.25rem}
.press-strip b{color:rgba(237,232,248,.55)}
.hero-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:3rem}
.hero-nums{display:flex;align-items:center;justify-content:center;gap:2rem;flex-wrap:wrap;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:1.25rem 2rem;max-width:600px;margin:0 auto}
.hn{display:flex;flex-direction:column;text-align:center}
.hn strong{font-size:1.9rem;font-weight:900;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.hn span{font-size:.68rem;color:var(--mt);text-transform:uppercase;letter-spacing:.08em;margin-top:.2rem}
.hdiv{width:1px;height:40px;background:rgba(255,255,255,.1)}

/* BIG RATING SECTION */
.rating-hero{background:var(--bk);padding:4rem 1.5rem 3.5rem;text-align:center;border-bottom:1px solid rgba(233,30,204,.12)}
.rh-stars-wrap{display:flex;align-items:flex-end;justify-content:center;gap:.5rem;margin-bottom:1.25rem;height:100px}
.rh-star{font-size:4rem;line-height:1;background:linear-gradient(180deg,#FFE566,#F59E0B,#D97706);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 4px 12px rgba(251,191,36,.6)) drop-shadow(0 0 30px rgba(251,191,36,.3));display:inline-block}
.rh-s1,.rh-s5{font-size:3rem;margin-bottom:.5rem}
.rh-s2,.rh-s4{font-size:3.75rem;margin-bottom:.25rem}
.rh-s3{font-size:4.5rem;margin-bottom:0}
.rh-sub{font-size:1rem;color:var(--tx);margin-bottom:.75rem}
.rh-score{font-size:clamp(1.75rem,5vw,2.75rem);font-weight:900;color:var(--wh);letter-spacing:.04em;text-transform:uppercase;margin-bottom:1.5rem}
.rh-btn{display:inline-block;background:var(--grad);color:#fff;font-weight:700;font-size:1rem;padding:.85rem 2.5rem;border-radius:999px;box-shadow:0 0 30px rgba(233,30,204,.4);transition:opacity .2s,box-shadow .2s}
.rh-btn:hover{opacity:.88;box-shadow:0 0 50px rgba(233,30,204,.6)}

/* AS SEEN IN */
.press-section{background:linear-gradient(180deg,var(--d3) 0%,var(--d2) 100%);padding:4.5rem 1.5rem;border-top:1px solid rgba(233,30,204,.25);border-bottom:1px solid rgba(233,30,204,.25);position:relative;overflow:hidden}
.press-section::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(233,30,204,.07),transparent 65%);pointer-events:none}
.press-headline{display:flex;align-items:center;justify-content:center;gap:1.5rem;margin-bottom:3rem}
.press-line{flex:1;max-width:200px;height:1px;background:linear-gradient(90deg,transparent,rgba(233,30,204,.5),transparent)}
.press-headline-text{font-size:.8rem;font-weight:800;letter-spacing:.3em;text-transform:uppercase;color:var(--pk);white-space:nowrap;text-shadow:0 0 20px rgba(233,30,204,.6)}
.press-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1.25rem;position:relative;z-index:1}
.press-card{display:flex;align-items:center;justify-content:center;padding:2rem 1.5rem;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:12px;transition:border-color .3s,box-shadow .3s,background .3s}
.press-card:hover{background:rgba(233,30,204,.06);border-color:rgba(233,30,204,.35);box-shadow:0 0 40px rgba(233,30,204,.12)}
.press-img{height:64px;width:100%;max-width:160px;object-fit:contain;filter:brightness(0) invert(1);opacity:.55;transition:opacity .3s,filter .3s}
.press-card:hover .press-img{opacity:1;filter:brightness(0) invert(1) drop-shadow(0 0 12px rgba(255,255,255,.5))}
@media(max-width:860px){.press-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:500px){.press-grid{grid-template-columns:repeat(2,1fr)}.press-img{height:44px}}

/* PACKAGE ITINERARY */
.itinerary{background:rgba(0,229,255,.05);border:1px solid rgba(0,229,255,.18);border-radius:8px;padding:.85rem 1rem;margin:.25rem 0}
.it-title{font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--cy);margin-bottom:.6rem}
.it-step{display:flex;gap:.75rem;align-items:baseline;font-size:.8rem;padding:.25rem 0;border-bottom:1px solid rgba(255,255,255,.05)}
.it-step:last-child{border-bottom:none}
.it-time{color:var(--pk2);font-weight:700;white-space:nowrap;min-width:52px;text-shadow:0 0 8px rgba(233,30,204,.5)}
.it-event{color:var(--tx);line-height:1.4}

/* TICKER */
.ticker-wrap{background:linear-gradient(90deg,rgba(233,30,204,.18),rgba(123,47,190,.18),rgba(0,229,255,.12),rgba(233,30,204,.18));border-top:2px solid rgba(233,30,204,.55);border-bottom:2px solid rgba(0,229,255,.35);padding:1rem 0;overflow:hidden;box-shadow:0 0 40px rgba(233,30,204,.15),inset 0 1px 0 rgba(255,255,255,.05)}
.ticker{display:flex;gap:3.5rem;white-space:nowrap;animation:tick 40s linear infinite}
.ticker span{font-size:.95rem;font-weight:800;color:var(--wh);letter-spacing:.02em;text-shadow:0 0 12px rgba(233,30,204,.5)}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* SECTIONS */
.section{padding:5.5rem 1.5rem}
.s-dark{background:var(--d2)}
.container{max-width:1100px;margin:0 auto}
.slabel{font-size:.68rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--pk);margin-bottom:.75rem;text-shadow:0 0 10px rgba(233,30,204,.45)}
h2{font-size:clamp(1.8rem,4vw,2.75rem);color:var(--wh);margin-bottom:.85rem}
.sdesc{color:var(--mt);font-size:1rem;max-width:640px;margin-bottom:3rem}

/* PERFECT FOR */
.pf-section{background:var(--d1)}
.pf-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem}
@media(max-width:900px){.pf-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.pf-grid{grid-template-columns:1fr}}
.pf-card{background:var(--d2);border:1px solid rgba(255,255,255,.06);border-radius:14px;overflow:hidden;display:flex;flex-direction:column;transition:border-color .25s,transform .25s,box-shadow .25s}
.pf-card:hover{border-color:rgba(233,30,204,.3);transform:translateY(-4px);box-shadow:0 16px 48px rgba(233,30,204,.1)}
.pf-img{height:200px;overflow:hidden}
.pf-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
.pf-card:hover .pf-img img{transform:scale(1.06)}
.pf-body{padding:1.5rem;display:flex;flex-direction:column;gap:.75rem;flex:1}
.pf-icon{font-size:1.75rem}
.pf-body h3{font-size:1rem;font-weight:800;color:var(--wh)}
.pf-body p{font-size:.85rem;color:var(--mt);line-height:1.7;flex:1}
.pf-btn{font-size:.82rem;font-weight:700;color:var(--pk2);border:1px solid rgba(233,30,204,.3);padding:.5rem 1rem;border-radius:6px;text-align:center;transition:background .2s,color .2s;display:block}
.pf-btn:hover{background:rgba(233,30,204,.12);color:var(--wh)}

/* BENTO */
.bento{padding:0;background:var(--d1)}
.bento-grid{display:grid;grid-template-columns:2fr 1fr 1fr;grid-template-rows:280px 280px;gap:3px}
.b{position:relative;overflow:hidden;cursor:pointer}
.b img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
.b:hover img{transform:scale(1.07)}
.b::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(6,6,8,.8) 0%,transparent 50%);opacity:0;transition:opacity .3s}
.b:hover::after{opacity:1}
.b-label{position:absolute;bottom:.9rem;left:1rem;z-index:2;font-size:.85rem;font-weight:700;color:#fff;opacity:0;transform:translateY(6px);transition:opacity .3s,transform .3s}
.b:hover .b-label{opacity:1;transform:translateY(0)}
.b1{grid-column:1/2;grid-row:1/3}
.b2{grid-column:2/3;grid-row:1/2}
.b3{grid-column:3/4;grid-row:1/2}
.b4{grid-column:2/3;grid-row:2/3}
.b5{grid-column:3/4;grid-row:2/3}
.b6{display:none}
.bento-cta{text-align:center;padding:2.5rem 1.5rem;background:var(--d1)}
@media(max-width:700px){
  .bento-grid{grid-template-columns:1fr 1fr;grid-template-rows:220px 220px 220px}
  .b1{grid-column:1/3;grid-row:1/2}
  .b2{grid-column:1/2;grid-row:2/3}
  .b3{grid-column:2/3;grid-row:2/3}
  .b4{grid-column:1/2;grid-row:3/4}
  .b5{grid-column:2/3;grid-row:3/4}
}

/* PACKAGES */
.pkgs{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
@media(max-width:860px){.pkgs{grid-template-columns:1fr;max-width:440px}}
.pkg{background:var(--d2);border:1px solid rgba(255,255,255,.07);border-radius:14px;overflow:hidden;display:flex;flex-direction:column;position:relative}
.pkg-hot{border-color:rgba(233,30,204,.45);box-shadow:0 0 60px rgba(233,30,204,.1)}
.pkg-pop{position:absolute;top:12px;right:12px;z-index:2;background:var(--grad);color:#fff;padding:.25rem .9rem;border-radius:999px;font-size:.72rem;font-weight:800;box-shadow:0 0 16px rgba(233,30,204,.5)}
.pkg-img{width:100%;height:190px;object-fit:cover}
.pkg-body{padding:1.5rem;display:flex;flex-direction:column;gap:.9rem;flex:1}
.pkg-dur{font-size:1.35rem;font-weight:900;color:var(--wh);text-transform:uppercase;letter-spacing:.04em;line-height:1.1}
.pkg-name{font-size:.85rem;color:var(--cy);font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-top:.1rem}
.pkg-price{display:flex;align-items:flex-start;line-height:1;font-size:3.2rem;font-weight:900;color:var(--pk)}
.pkg-price sup{font-size:1.3rem;margin-top:.3rem}
.pkg-price em{font-size:.82rem;font-style:normal;color:var(--mt);align-self:flex-end;margin-bottom:.3rem;margin-left:.15rem}
.pkg ul{list-style:none;display:flex;flex-direction:column;gap:.5rem;flex:1}
.pkg li{font-size:.875rem;color:var(--tx);padding-left:1.35rem;position:relative}
.pkg li::before{content:'✓';position:absolute;left:0;color:var(--cy);font-weight:700}
.pkg-note{font-size:.78rem;color:var(--mt);background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:6px;padding:.6rem .85rem;line-height:1.55}
.pkg-omnia{background:linear-gradient(135deg,rgba(233,30,204,.12),rgba(0,229,255,.06));border:1px solid rgba(233,30,204,.38);border-radius:8px;padding:.9rem 1rem;font-size:.84rem;color:var(--tx);line-height:1.65}
.pkg-omnia strong{color:var(--wh)}
.omnia-badge{display:inline-block;background:var(--grad);color:#fff;font-size:.65rem;font-weight:800;letter-spacing:.1em;padding:.2rem .65rem;border-radius:999px;margin-bottom:.4rem;box-shadow:0 0 12px rgba(233,30,204,.4)}
.pkg-btn{display:block;text-align:center;background:rgba(255,255,255,.07);color:var(--wh);font-weight:700;font-size:.9rem;padding:.85rem;border-radius:8px;border:1px solid rgba(255,255,255,.1);transition:background .2s}
.pkg-btn:hover{background:rgba(255,255,255,.13)}
.pkg-btn-hot{background:var(--grad);border-color:transparent;box-shadow:0 0 24px rgba(233,30,204,.4)}
.pkg-btn-hot:hover{opacity:.88}

/* PROMO */
.promo-section{background:var(--d1)}
.promo-banner{position:relative;background:linear-gradient(135deg,rgba(123,47,190,.16),rgba(0,229,255,.06));border:1px solid rgba(233,30,204,.3);border-radius:20px;overflow:hidden;padding:3rem;box-shadow:0 0 80px rgba(233,30,204,.07)}
.promo-glow{position:absolute;top:-100px;right:-80px;width:450px;height:450px;background:radial-gradient(circle,rgba(233,30,204,.18),transparent 70%);pointer-events:none}
.promo-content{display:grid;grid-template-columns:1fr 380px;gap:3rem;align-items:center;position:relative;z-index:1}
@media(max-width:860px){.promo-content{grid-template-columns:1fr}.promo-right{display:none}}
.promo-tag{display:inline-block;background:var(--grad);color:#fff;font-size:.72rem;font-weight:800;letter-spacing:.12em;padding:.35rem 1rem;border-radius:999px;margin-bottom:1.25rem;box-shadow:0 0 24px rgba(233,30,204,.45)}
.promo-title{font-size:clamp(1.5rem,3vw,2.2rem);color:var(--wh);margin-bottom:1rem}
.promo-desc{color:rgba(237,232,248,.75);font-size:.95rem;line-height:1.75;margin-bottom:1.5rem}
.promo-desc strong{color:var(--wh)}
.promo-desc em{font-style:normal;color:var(--cy)}
.promo-list{list-style:none;display:flex;flex-direction:column;gap:.6rem;margin-bottom:1.75rem}
.promo-list li{font-size:.9rem;color:var(--tx)}
.promo-compare{display:flex;align-items:center;gap:1rem;margin-bottom:2rem;flex-wrap:wrap}
.pc-item{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:.75rem 1.25rem;text-align:center}
.pc-item span{display:block;font-size:.72rem;color:var(--mt);margin-bottom:.25rem}
.pc-item strong{display:block;font-size:1.1rem;font-weight:800;color:var(--tx)}
.pc-yes{border-color:rgba(233,30,204,.35);background:rgba(233,30,204,.08)}
.pc-yes strong{color:var(--pk2)}
.pc-arr{color:var(--pk);font-size:1.5rem;font-weight:300}
.promo-right{position:relative;border-radius:14px;overflow:hidden}
.promo-right img{width:100%;height:320px;object-fit:cover;border-radius:14px}
.promo-pill{position:absolute;bottom:1rem;left:50%;transform:translateX(-50%);background:var(--grad);color:#fff;font-size:.8rem;font-weight:800;padding:.5rem 1.25rem;border-radius:999px;white-space:nowrap;box-shadow:0 0 24px rgba(233,30,204,.55)}

/* ADD-ONS */
.addons-section{background:var(--d2)}
.addon-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-bottom:1.25rem}
@media(max-width:700px){.addon-grid{grid-template-columns:1fr}}
.addon-card{background:var(--d3);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:1.75rem;display:flex;flex-direction:column;gap:.85rem;transition:border-color .25s}
.addon-card:hover{border-color:rgba(233,30,204,.22)}
.addon-icon{font-size:2rem}
.addon-card h4{font-size:1rem;font-weight:700;color:var(--wh)}
.addon-card p{font-size:.875rem;color:var(--mt);line-height:1.7;flex:1}
.addon-card strong{color:var(--pk)}
.addon-card em{font-style:normal;color:var(--tx)}
.addon-price-block{display:flex;flex-direction:column;gap:.15rem;margin-top:auto}
.addon-cost{font-size:1.75rem;font-weight:900;color:var(--cy);line-height:1}
.addon-was{font-size:.72rem;color:var(--mt)}
.addon-note{font-size:.85rem;color:var(--mt);text-align:center}
.addon-note a{color:var(--pk);text-decoration:underline}

/* CLUB FINDER */
.finder-layout{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start}
@media(max-width:800px){.finder-layout{grid-template-columns:1fr}}
.finder-top{background:var(--d3);border-radius:12px;border:1px solid rgba(233,30,204,.28);padding:2.5rem;margin-bottom:1.25rem;text-align:center;box-shadow:0 0 50px rgba(233,30,204,.06)}
.finder-top label{display:block;font-size:.75rem;text-transform:uppercase;letter-spacing:.12em;color:var(--pk);font-weight:700;margin-bottom:1rem}
#eDate{background:rgba(255,255,255,.07);border:2px solid rgba(233,30,204,.3);color:var(--wh);font-size:1.1rem;font-weight:600;padding:.85rem 1.75rem;border-radius:8px;cursor:pointer;outline:none;color-scheme:dark;width:100%;max-width:300px;transition:border-color .2s}
#eDate:focus{border-color:var(--pk);box-shadow:0 0 20px rgba(233,30,204,.25)}
.f-hint{font-size:.8rem;color:var(--mt);margin-top:.85rem}
.f-results{background:var(--d3);border-radius:12px;border:1px solid rgba(0,229,255,.18);padding:2rem;box-shadow:0 0 40px rgba(0,229,255,.05)}
.f-results.hidden{display:none}
.f-day{font-size:1.15rem;font-weight:800;color:var(--wh);margin-bottom:.3rem}
.f-count{font-size:.85rem;color:var(--cy);margin-bottom:1.25rem}
.f-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:.65rem;margin-bottom:1.25rem}
.f-chip{background:rgba(0,229,255,.07);border:1px solid rgba(0,229,255,.22);border-radius:8px;padding:.65rem .9rem;font-size:.84rem;font-weight:600;color:var(--tx);display:flex;align-items:center;gap:.5rem}
.f-chip::before{content:'✓';color:var(--cy);font-size:.8rem;flex-shrink:0}
.f-blackout{background:rgba(255,160,0,.07);border:1px solid rgba(255,160,0,.22);border-radius:8px;padding:1rem 1.25rem;font-size:.84rem;color:rgba(237,232,248,.85);margin-bottom:1.25rem}
.f-blackout.hidden{display:none}
.f-blackout a{color:var(--pk);text-decoration:underline}
.f-btns{display:flex;gap:1rem;flex-wrap:wrap}
.club-chart{background:var(--d3);border:1px solid rgba(255,255,255,.06);border-radius:12px;overflow:hidden}
.cc-label{font-size:.72rem;text-transform:uppercase;letter-spacing:.1em;color:var(--mt);font-weight:700;padding:1rem 1.25rem .75rem}
.club-chart img{width:100%;height:auto}

/* HOW IT WORKS */
.hiw-section{background:var(--d1)}
.steps{display:grid;grid-template-columns:1fr auto 1fr auto 1fr auto 1fr;gap:1.25rem;align-items:start}
@media(max-width:900px){.steps{grid-template-columns:1fr 1fr}.sarr{display:none}}
@media(max-width:500px){.steps{grid-template-columns:1fr}}
.step{display:flex;flex-direction:column;gap:.85rem}
.sn{font-size:2.75rem;font-weight:900;line-height:1;background:linear-gradient(135deg,var(--pk),var(--cy));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 8px rgba(233,30,204,.4))}
.step img{width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:10px;border:1px solid rgba(255,255,255,.06)}
.step h3{font-size:.95rem;font-weight:800;color:var(--wh)}
.step p{font-size:.84rem;color:var(--mt);line-height:1.7}
.sarr{font-size:1.5rem;color:var(--pk);padding-top:3rem;opacity:.45}

/* PHOTO ROW */
.photo-row{display:grid;grid-template-columns:repeat(6,1fr);height:240px;gap:3px}
.photo-row img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.photo-row img:hover{transform:scale(1.05);z-index:1;position:relative}
@media(max-width:700px){.photo-row{grid-template-columns:repeat(3,1fr);height:280px}}

/* WHY GXP */
.why-section{background:var(--bk)}
.why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem}
@media(max-width:800px){.why-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.why-grid{grid-template-columns:1fr}}
.why-card{background:var(--d2);border:1px solid rgba(255,255,255,.06);border-radius:14px;padding:1.75rem;transition:border-color .25s,box-shadow .25s,transform .25s}
.why-card:hover{border-color:rgba(233,30,204,.35);box-shadow:0 0 40px rgba(233,30,204,.12),0 0 1px rgba(233,30,204,.5);transform:translateY(-3px)}
.why-num{font-size:2.5rem;font-weight:900;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;margin-bottom:.75rem;filter:drop-shadow(0 0 10px rgba(233,30,204,.35))}
.why-card h4{font-size:.95rem;font-weight:800;color:var(--wh);margin-bottom:.5rem}
.why-card p{font-size:.85rem;color:var(--mt);line-height:1.7}

/* REVIEWS */
.review-hero{display:grid;grid-template-columns:auto 1px auto 1px 1fr;gap:2.5rem;align-items:center;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:2.5rem;margin-bottom:2.5rem}
@media(max-width:800px){.review-hero{grid-template-columns:1fr;gap:1.5rem}.rh-divider{display:none}}
.rh-left{text-align:center}
