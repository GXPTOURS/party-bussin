<script>
// Mobile nav
const burger = document.getElementById('burger');
const mobNav = document.getElementById('mob-nav');
burger?.addEventListener('click', () => mobNav?.classList.toggle('open'));
mobNav?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mobNav?.classList.remove('open')));

// Club finder
const schedule: Record<number,{clubs:string[];blackout:boolean}> = {
  0:{clubs:['XS at Encore','Hakkasan at MGM Grand','Marquee at Cosmopolitan','Zouk at Resorts World','Foundation Room at Mandalay Bay'],blackout:false},
  1:{clubs:['On The Record at Park MGM','Foundation Room at Mandalay Bay','Ghostbar at Palms'],blackout:false},
  2:{clubs:['On The Record at Park MGM','Foundation Room at Mandalay Bay','Ghostbar at Palms'],blackout:false},
  3:{clubs:['Marquee at Cosmopolitan','Omnia at Caesars Palace','Tao at Venetian','On The Record at Park MGM','Zouk at Resorts World'],blackout:false},
  4:{clubs:['Marquee at Cosmopolitan','Hakkasan at MGM Grand','Omnia at Caesars Palace','Tao at Venetian','Foundation Room at Mandalay Bay','LIV at Fontainebleau'],blackout:false},
  5:{clubs:['Jewel at Aria','Marquee at Cosmopolitan','Hakkasan at MGM Grand','Omnia at Caesars Palace','XS at Encore','Zouk at Resorts World','LIV at Fontainebleau','Tao at Venetian','EBC @ Night at Encore','Foundation Room at Mandalay Bay'],blackout:true},
  6:{clubs:['Jewel at Aria','Marquee at Cosmopolitan','Hakkasan at MGM Grand','Omnia at Caesars Palace','XS at Encore','Zouk at Resorts World','LIV at Fontainebleau','Tao at Venetian','EBC @ Night at Encore','Foundation Room at Mandalay Bay','On The Record at Park MGM'],blackout:true},
};
const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const inp = document.getElementById('eDate') as HTMLInputElement;
const res = document.getElementById('fResults');
const now = new Date();
inp.min = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
inp?.addEventListener('change',()=>{
  const [y,m,d] = inp.value.split('-').map(Number);
  if(!y) return;
  const date = new Date(y,m-1,d);
  const day = date.getDay();
  const data = schedule[day];
  const fDay = document.getElementById('fDay');
  const fCount = document.getElementById('fCount');
  const fGrid = document.getElementById('fGrid');
  const fBlackout = document.getElementById('fBlackout');
  if(fDay) fDay.textContent = `${days[day]}, ${date.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}`;
  if(fCount) fCount.textContent = `${data.clubs.length} clubs typically available`;
  if(fGrid) fGrid.innerHTML = data.clubs.map(c=>`<div class="f-chip">${c}</div>`).join('');
  fBlackout?.classList.toggle('hidden',!data.blackout);
  res?.classList.remove('hidden');
});
</script>
