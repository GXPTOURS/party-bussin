        </ul>
        <a href="https://gxptours.rezdy.com" target="_blank" class="pkg-cta">Book This Package</a>
      </div>

      <div class="pkg-card pkg-featured">
        <div class="pkg-popular">⭐ Most Popular</div>
        <div class="pkg-header">
          <div class="pkg-name">Coyote Ugly</div>
          <div class="pkg-tag">2-Hour Bus</div>
        </div>
        <div class="pkg-price"><sup>$</sup>139<em>/person</em></div>
        <ul>
          <li>Coyote Ugly lounge entry</li>
          <li><strong>2-hour private party bus</strong></li>
