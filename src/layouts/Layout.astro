---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Party Bussin' — Vegas' first all-ages party bus experience. Party bus + Sky Zone + pizza party, all-inclusive. Book your kid's best birthday ever." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Fredoka+One&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange:  #FF6B00;
      --yellow:  #FFD600;
      --pink:    #FF3FA4;
      --purple:  #6B21D6;
      --purple-mid: #8B3FE8;
      --purple-light: #A865F5;
      --blue:    #1BAAFF;
      --teal:    #00D9C0;
      --dark:    #120C2A;
      --dark-2:  #1A1240;
      --dark-3:  #221955;
      --text:    #F0EAFF;
      --text-muted: #9A8EC0;
      --white:   #FFFFFF;
      --grad-fun: linear-gradient(135deg, #FF6B00, #FF3FA4, #6B21D6);
      --grad-text: linear-gradient(90deg, #FF6B00, #FFD600);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--dark);
      color: var(--text);
      line-height: 1.6;
    }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }
    .grad {
      background: var(--grad-text);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
