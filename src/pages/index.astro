  <div class="trust-wrap">
    <span>✓ Private Group Only</span>
    <span>✓ Champagne Included</span>
    <span>✓ Las Vegas Sign Stop</span>
    <span>✓ VIP Nightclub Entry</span>
    <span>✓ BYOB Friendly</span>
