---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Las Vegas Nightclub on Wheels — Party bus + VIP nightclub entry from $99/person. 4.9★ rated, 17 years of Vegas expertise. Book your group night out today." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --pink: #E91ECC;
      --pink-bright: #FF3DE8;
      --purple: #7B2FBE;
      --purple-light: #9B4FDE;
      --cyan: #00E5FF;
      --cyan-dim: #00BFDD;
      --black: #060608;
      --dark: #0D0D12;
      --dark-2: #13131A;
      --dark-3: #1A1A24;
      --text: #EEE8F8;
      --text-muted: #8880A0;
      --white: #FFFFFF;
      --gradient: linear-gradient(135deg, var(--pink), var(--purple));
      --gradient-text: linear-gradient(90deg, #FF3DE8, #7B2FBE, #00E5FF);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--black);
      color: var(--text);
      line-height: 1.6;
    }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }
    .neon-text {
      background: var(--gradient-text);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .glow-pink { text-shadow: 0 0 20px rgba(233,30,204,0.6), 0 0 40px rgba(233,30,204,0.3); }
    .glow-cyan { text-shadow: 0 0 20px rgba(0,229,255,0.6), 0 0 40px rgba(0,229,255,0.3); }
  </style>
</head>
<body>
  <slot />
</body>
</html>
