  const [y, m, d] = val.split('-').map(Number);
  const date = new Date(y, m - 1, d);
  const dayNum = date.getDay();
  const data = clubData[dayNum as keyof typeof clubData];
  const dayName = days[dayNum];

  if (resultsDay) resultsDay.textContent = `${dayName}, ${date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`;
  if (resultsCount) resultsCount.textContent = `${data.clubs.length} clubs typically available`;

  if (clubGrid) {
    clubGrid.innerHTML = data.clubs.map(c => `<div class="club-pill">${c}</div>`).join('');
  }

  if (blackoutNote) {
    blackoutNote.classList.toggle('hidden', !data.blackout);
  }

  clubResults?.classList.remove('hidden');
});
</script>
