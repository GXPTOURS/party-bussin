      <div class="pkg-card">
        <div class="pkg-header">
          <div class="pkg-name">Coyote Ugly Meetup</div>
          <div class="pkg-tag">1-Hour Bus</div>
        </div>
        <div class="pkg-price"><sup>$</sup>99<em>/person</em></div>
        <ul>
          <li>Coyote Ugly lounge entry</li>
          <li>1-hour private party bus</li>
          <li>Champagne & beverages</li>
          <li>Las Vegas Sign photo stop</li>
          <li>VIP nightclub entry</li>
