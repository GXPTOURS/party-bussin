<style>
/* ── RESET ── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --pink:#E91ECC;
  --pink-b:#FF3DE8;
  --purple:#7B2FBE;
  --purple-l:#9B4FDE;
  --cyan:#00E5FF;
  --black:#060608;
  --dark:#0D0D14;
  --dark2:#13131C;
  --dark3:#1C1C28;
  --text:#EDE8F8;
  --muted:#7870A0;
  --white:#fff;
}
html{scroll-behavior:smooth}
body{font-family:'Inter',system-ui,sans-serif;background:var(--black);color:var(--text);line-height:1.65;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}
h1,h2,h3,h4,h5{line-height:1.15;font-weight:800}
.neon-text{background:linear-gradient(90deg,#FF3DE8,#9B4FDE,#00E5FF);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

/* ── BUTTONS ── */
.btn-primary{
  display:inline-flex;align-items:center;gap:.35rem;
  background:linear-gradient(135deg,var(--pink),var(--purple));
  color:#fff;font-weight:700;font-size:.95rem;
  padding:.9rem 2rem;border-radius:8px;
  box-shadow:0 0 24px rgba(233,30,204,.35);
  transition:opacity .2s,transform .15s,box-shadow .2s;white-space:nowrap
}
.btn-primary:hover{opacity:.9;transform:translateY(-2px);box-shadow:0 0 36px rgba(233,30,204,.55)}
.btn-ghost{
  display:inline-flex;align-items:center;gap:.35rem;
  background:transparent;color:var(--white);font-weight:600;font-size:.95rem;
  padding:.9rem 2rem;border-radius:8px;
  border:2px solid rgba(255,255,255,.2);
  transition:border-color .2s,color .2s;white-space:nowrap
}
.btn-ghost:hover{border-color:var(--cyan);color:var(--cyan)}
.btn-xl{padding:1.1rem 2.6rem;font-size:1.05rem}

/* ── NAV ── */
#nav{
  position:sticky;top:0;z-index:200;
  background:rgba(6,6,8,.94);backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(233,30,204,.2)
}
.nav-wrap{
  max-width:1200px;margin:0 auto;
  padding:0 1.5rem;height:70px;
  display:flex;align-items:center;gap:2rem
}
